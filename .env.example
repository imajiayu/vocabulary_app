# ===================================
# Vercel 部署环境变量配置
# ===================================

# Supabase 数据库连接字符串
# 格式: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# 获取方式:
# 1. 登录 https://supabase.com/dashboard
# 2. 选择项目 → Settings → Database → Connection string
# 3. 选择 "URI" 格式，复制连接字符串
# 4. 将 [YOUR-PASSWORD] 替换为你的数据库密码
DATABASE_URL=postgresql://postgres.xxx:[YOUR-PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# Flask Secret Key（用于 session 加密）
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# DeepSeek API Key（用于 AI 辅助功能，前后端共用）
# 获取方式: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxx

# ===================================
# 前端环境变量（VITE_ 前缀）
# ===================================

# 后端 API 基础 URL
# Vercel 同域部署时留空
VITE_API_BASE_URL=
