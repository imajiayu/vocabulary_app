            {
              "prompt": "<strong><span class=\"uk-word\" data-def=\"老师\">Вчитель</span></strong> тут.",
              "options": ["主格", "宾格"],
              "answer": "主格",
              "explanation": "вчитель 是主语 → 主格 = 字典原形。"
            },
            {
              "prompt": "Я бачу <strong><span class=\"uk-word\" data-def=\"老师（宾格）\">вчителя</span></strong>.",
              "options": ["主格", "宾格"],
              "answer": "宾格",
              "explanation": "宾语 → 宾格。вчитель → вчителя（-ь → -я）。"
            }
          ]
        },
