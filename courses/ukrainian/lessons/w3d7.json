          "style": "quiz",
          "title": "练习 A：判断主格还是宾格（10题）",
          "instruction": "判断下面句子中加粗的名词处于哪个格。",
          "questions": [
            {
              "prompt": "Це <strong><span class=\"uk-word\" data-def=\"书\">книга</span></strong>.",
              "options": ["主格", "宾格"],
              "answer": "主格",
              "explanation": "Це 后面的名词是主格。"
            },
            {
              "prompt": "Я читаю <strong><span class=\"uk-word\" data-def=\"书（宾格）\">книгу</span></strong>.",
              "options": ["主格", "宾格"],
              "answer": "宾格",
              "explanation": "动词 читаю 的对象 → 宾格。形式上看：книга → книгу。"
            },
            {
              "prompt": "<strong><span class=\"uk-word\" data-def=\"猫\">Кіт</span></strong> тут.",
              "options": ["主格", "宾格"],
              "answer": "主格",
              "explanation": "кіт 是主语 → 主格。"
            },
            {
              "prompt": "Я бачу <strong><span class=\"uk-word\" data-def=\"猫（宾格）\">кота</span></strong>.",
              "options": ["主格", "宾格"],
              "answer": "宾格",
              "explanation": "宾语 → 宾格。кіт→кота 是有生命阳性的飘忽元音变化。"
            },
            {
              "prompt": "<strong><span class=\"uk-word\" data-def=\"咖啡\">Кава</span></strong> там.",
              "options": ["主格", "宾格"],
              "answer": "主格",
              "explanation": "кава 是主语 → 主格。"
            },
            {
              "prompt": "Я п'ю <strong><span class=\"uk-word\" data-def=\"咖啡（宾格）\">каву</span></strong>.",
