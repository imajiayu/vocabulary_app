            { "text": "Ми — друзі.", "translation": "我们是朋友。" },
            { "text": "Хто це? — Це Іван.", "translation": "这是谁？— 这是 Іван。" }
          ]
        }
      ]
    },

    {
      "type": "exercises",
      "heading": "3. 练习题",
      "groups": [
        {
          "style": "quiz",
          "title": "练习 A：找出主语（10题）",
          "instruction": "在下面每个句子中，找出充当主语的词。",
          "questions": [
            {
              "prompt": "<span class=\"uk-word\" data-def=\"桌子\">Стіл</span> <span class=\"uk-word\" data-def=\"在这里\">тут</span>.",
