            },
            {
              "prompt": "<span class=\"uk-word\" data-def=\"书\">Книга</span> <span class=\"uk-word\" data-def=\"在那里\">там</span>.",
              "options": ["книга", "там", "це"],
              "answer": "книга",
              "explanation": "книга 是主语，там 是位置副词。"
