# ===================================
# 前端环境变量配置（VITE_ 前缀，Vite 自动注入到 import.meta.env）
# ===================================
# 复制此文件为 .env.local 并填入实际值
#
# ⚠️ 警告：VITE_ 前缀的变量会被 Vite 构建时硬编码进 JS bundle，对所有访客可见。
#    只能放公开凭证（anon key / 受 RLS 保护的资源）。
#    禁止放任何需要保密的 API key。
#    外部 AI（LLM / STT / TTS）的 key 全部收敛在 backend/.env，前端通过
#    Flask `/api/ai/*` 代理调用，不在前端出现。

# --- 必填 ---

# Supabase 项目 URL
VITE_SUPABASE_URL=https://xxx.supabase.co

# Supabase Anonymous Key（公开，RLS 保护数据安全）
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- 可选：后端 API 基址 ---

# 本地开发留空（走 Vite 代理 /api → 后端 :5001）
# 生产填后端完整 URL，如 https://mieltsm.top
VITE_API_BASE_URL=
