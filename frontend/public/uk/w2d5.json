      ],
      "groups": [
        {
          "style": "quiz",
          "title": "练习A：选出正确的中性名词复数形式（8题）",
          "instruction": "根据中性名词复数规则，选出正确的复数形式。",
          "questions": [
            {
              "prompt": "<span class=\"uk-word\" data-def=\"窗户\">вікно</span>（窗户）的复数是？",
              "options": ["<span class=\"uk-word\">вікна</span>", "<span class=\"uk-word\">вікни</span>", "<span class=\"uk-word\" data-def=\"窗户\">вікно</span>"],
              "answer": "вікна",
              "explanation": "вікно 以 -о 结尾 → 去-о 加-а → вікна"
            },
            {
              "prompt": "<span class=\"uk-word\" data-def=\"床\">ліжко</span>（床）的复数是？",
              "options": ["<span class=\"uk-word\">ліжки</span>", "<span class=\"uk-word\">ліжка</span>", "<span class=\"uk-word\" data-def=\"床\">ліжко</span>"],
              "answer": "ліжка",
              "explanation": "ліжко 以 -о 结尾 → 去-о 加-а → ліжка"
            },
            {
              "prompt": "<span class=\"uk-word\" data-def=\"海\">море</span>（海）的复数是？",
              "options": ["<span class=\"uk-word\">морі</span>", "<span class=\"uk-word\">моря</span>", "<span class=\"uk-word\">мора</span>"],
              "answer": "моря",
              "explanation": "море 以 -е 结尾 → 去-е 加-я → моря"
            },
            {
              "prompt": "<span class=\"uk-word\" data-def=\"地方\">місце</span>（地方）的复数是？",
              "options": ["<span class=\"uk-word\">місця</span>", "<span class=\"uk-word\">місці</span>", "<span class=\"uk-word\">місца</span>"],
              "answer": "місця",
              "explanation": "місце 以 -е 结尾 → 去-е 加-я → місця"
            },
            {
              "prompt": "<span class=\"uk-word\" data-def=\"桨\">весло</span>（桨）的复数是？",
              "options": ["<span class=\"uk-word\">весла</span>", "<span class=\"uk-word\">весли</span>", "<span class=\"uk-word\" data-def=\"桨\">весло</span>"],
              "answer": "весла",
              "explanation": "весло 以 -о 结尾 → 去-о 加-а → весла"
            },
            {
              "prompt": "<span class=\"uk-word\" data-def=\"翅膀\">крило</span>（翅膀）的复数是？",
              "options": ["<span class=\"uk-word\">крила</span>", "<span class=\"uk-word\">крилі</span>", "<span class=\"uk-word\" data-def=\"翅膀\">крило</span>"],
              "answer": "крила",
              "explanation": "крило 以 -о 结尾 → 去-о 加-а → крила"
            },
            {
              "prompt": "<span class=\"uk-word\" data-def=\"数字\">число</span>（数字）的复数是？",
              "options": ["<span class=\"uk-word\">числи</span>", "<span class=\"uk-word\">числа</span>", "<span class=\"uk-word\" data-def=\"数字\">число</span>"],
              "answer": "числа",
              "explanation": "число 以 -о 结尾 → 去-о 加-а → числа"
            },
            {
              "prompt": "<span class=\"uk-word\" data-def=\"心脏\">серце</span>（心脏）的复数是？",
              "options": ["<span class=\"uk-word\">серці</span>", "<span class=\"uk-word\">серця</span>", "<span class=\"uk-word\">серца</span>"],
              "answer": "серця",
              "explanation": "серце 以 -е 结尾 → 去-е 加-я → серця"
            }
          ]
        },
        {
          "style": "quiz",
          "title": "练习B：三种性别复数对比（5题）",
          "instruction": "给出一个名词，先判断性别，再选正确的复数形式。",
          "questions": [
            {
              "prompt": "<span class=\"uk-word\" data-def=\"单词\">слово</span>（单词）的复数是？",
              "options": ["<span class=\"uk-word\">слови</span>", "<span class=\"uk-word\">слова</span>", "<span class=\"uk-word\">слові</span>"],
              "answer": "слова",
              "explanation": "слово 是中性（-о 结尾），复数 -о→-а → слова"
            },
            {
              "prompt": "<span class=\"uk-word\" data-def=\"盘子\">тарілка</span>（盘子）的复数是？",
              "options": ["<span class=\"uk-word\">тарілки</span>", "<span class=\"uk-word\" data-def=\"盘子\">тарілка</span>", "<span class=\"uk-word\">тарілкі</span>"],
              "answer": "тарілки",
