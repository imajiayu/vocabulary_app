            },
            {
              "prompt": "<span class=\"uk-word\" data-def=\"建筑\">будинок</span>（房子）的复数是？",
              "options": ["<span class=\"uk-word\">будинки</span>", "<span class=\"uk-word\">будинка</span>", "<span class=\"uk-word\">будинкі</span>"],
              "answer": "будинки",
              "explanation": "будинок 是阳性（辅音结尾），复数加 -и → будинки"
            },
            {
              "prompt": "<span class=\"uk-word\" data-def=\"田野\">поле</span>（田野）的复数是？",
              "options": ["<span class=\"uk-word\">полі</span>", "<span class=\"uk-word\">поля</span>", "<span class=\"uk-word\">поли</span>"],
              "answer": "поля",
              "explanation": "поле 是中性（-е 结尾），复数 -е→-я → поля"
            },
            {
              "prompt": "<span class=\"uk-word\" data-def=\"裙子\">сукня</span>（连衣裙）的复数是？",
              "options": ["<span class=\"uk-word\" data-def=\"裙子\">сукня</span>", "<span class=\"uk-word\">сукні</span>", "<span class=\"uk-word\">сукна</span>"],
              "answer": "сукні",
              "explanation": "сукня 是阴性（-я 结尾），复数 -я→-і → сукні"
            }
          ]
