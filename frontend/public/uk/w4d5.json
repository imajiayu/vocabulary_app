            { "text": "Я іду в магазин.", "translation": "我去商店。（магазин 阳无生命 → 不变）" },
            { "text": "Я іду на роботу.", "translation": "我去上班。（робота → роботу）" }
          ]
        },
        {
          "heading": "复数无生命宾格 = 复数主格",
          "items": [
            { "text": "Я купую яблука.", "translation": "我买苹果（复）。（яблука → 不变）" },
            { "text": "Я люблю книги.", "translation": "我喜欢书（复）。（книги → 不变）" },
            { "text": "Я читаю газети.", "translation": "我读报纸（复）。（газети → 不变）" }
          ]
        }
      ]
