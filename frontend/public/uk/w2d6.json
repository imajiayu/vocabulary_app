            {
              "prompt": "<span class=\"uk-word\" data-def=\"名字\">ім'я</span>（名字）的复数是？",
              "options": ["<span class=\"uk-word\">ім'ї</span>", "<span class=\"uk-word\">імена</span>", "<span class=\"uk-word\" data-def=\"名字\">ім'я</span>"],
