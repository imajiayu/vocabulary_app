            {
              "prompt": "<span class=\"uk-word\">люди</span>（人们）的单数是？",
              "options": ["<span class=\"uk-word\" data-def=\"人\">людина</span>", "<span class=\"uk-word\" data-def=\"孩子\">дитина</span>", "<span class=\"uk-word\">люд</span>"],
