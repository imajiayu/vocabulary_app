          "questions": [
            {
              "prompt": "<span class=\"uk-word\" data-def=\"孩子\">дитина</span>（孩子）的复数是？",
              "options": ["<span class=\"uk-word\">дитини</span>", "<span class=\"uk-word\">діти</span>", "<span class=\"uk-word\">дитята</span>"],
