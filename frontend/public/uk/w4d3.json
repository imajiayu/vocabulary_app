            ["дитина", "<span class=\"uk-word\" data-def=\"孩子们\">діти</span>", "孩子 → 孩子们", "「孩子」整体换词"],
            ["друг", "<span class=\"uk-word\" data-def=\"朋友们\">друзі</span>", "朋友 → 朋友们", "辅音 г → з + -і"],
            ["око", "<span class=\"uk-word\" data-def=\"眼睛（复）\">очі</span>", "眼睛", "整体换词"],
            ["вухо", "<span class=\"uk-word\" data-def=\"耳朵（复）\">вуха</span>", "耳朵", "走中性 -о → -а 的常规路（不算很不规则）"],
            ["ім'я", "<span class=\"uk-word\" data-def=\"名字（复）\">імена</span>", "名字", "中性 -я 类异常"],
            ["плем'я", "<span class=\"uk-word\" data-def=\"部落（复）\">племена</span>", "部落", "同 ім'я 类型"],
            ["мати", "<span class=\"uk-word\" data-def=\"妈妈们\">матері</span>", "母亲", "整体换词"],
            ["брат", "<span class=\"uk-word\" data-def=\"兄弟们\">брати</span>", "兄弟（复）", "常规阳性 -и，但读音重音变化"]
