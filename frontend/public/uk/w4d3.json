            ["阳性", "-к / -г / -х （后舌音）", "-и", "<span class=\"uk-word\" data-def=\"公园\">парк</span> → <span class=\"uk-word\" data-def=\"公园（复）\">парки</span>"],
            ["阳性", "ь / -й", "-і", "<span class=\"uk-word\" data-def=\"老师（阳）\">вчитель</span> → <span class=\"uk-word\" data-def=\"老师们\">вчителі</span>"],
            ["阴性", "-а", "-и", "<span class=\"uk-word\" data-def=\"书\">книга</span> → <span class=\"uk-word\" data-def=\"书（复）\">книги</span>"],
            ["阴性", "-я", "-і", "<span class=\"uk-word\" data-def=\"厨房\">кухня</span> → <span class=\"uk-word\" data-def=\"厨房（复）\">кухні</span>"],
            ["阴性", "ь / -ість", "-і", "<span class=\"uk-word\" data-def=\"夜晚\">ніч</span> → <span class=\"uk-word\" data-def=\"夜晚（复）\">ночі</span>；<span class=\"uk-word\" data-def=\"喜悦\">радість</span> → <span class=\"uk-word\" data-def=\"喜悦（复）\">радості</span>"],
            ["中性", "-о", "-а", "<span class=\"uk-word\" data-def=\"窗户\">вікно</span> → <span class=\"uk-word\" data-def=\"窗户（复）\">вікна</span>"],
            ["中性", "-е", "-я", "<span class=\"uk-word\" data-def=\"心脏\">серце</span> → <span class=\"uk-word\" data-def=\"心脏（复）\">серця</span>"],
            ["中性", "-ння / -ття", "-ння (不变)", "<span class=\"uk-word\" data-def=\"作业\">завдання</span> → <span class=\"uk-word\" data-def=\"作业（复）\">завдання</span>（拼写不变，重音可能移动）"]
          ]
        },
        { "type": "tip", "html": "<strong>速记诀：</strong>「<strong>阳辅 -и、阳ь -і；阴 -а -и、阴 -я -і；中 -о -а、中 -е -я」</strong>。后舌音（к/г/х）属于阳性，但走 -и 的路。" },

        { "type": "h3", "text": "ь 结尾词的复数 —— 注意软音的位置" },
        { "type": "p", "html": "ь 结尾词变复数时，ь 会消失，换成 -і（因为 -і 本身就是软元音）。看几组对比：" },
        {
          "type": "table",
