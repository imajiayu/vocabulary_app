      "groups": [
        {
          "heading": "三性复数对比",
          "items": [
            { "text": "Це столи.", "translation": "这是几张桌子。（阳 -и）" },
            { "text": "Це парки.", "translation": "这是公园（复）。（阳后舌音 -и）" },
            { "text": "Це вчителі.", "translation": "这是老师们。（阳 ь → -і）" },
            { "text": "Це книги.", "translation": "这是书（复）。（阴 -а → -и）" },
            { "text": "Це кухні.", "translation": "这是厨房（复）。（阴 -я → -і）" },
            { "text": "Це ночі.", "translation": "这是夜晚（复）。（阴 ь → -і）" },
            { "text": "Це вікна.", "translation": "这是窗户（复）。（中 -о → -а）" },
            { "text": "Це серця.", "translation": "这是心脏（复）。（中 -е → -я）" }
          ]
        },
        {
          "heading": "飘忽元音 + 不规则复数",
          "items": [
            { "text": "Хлопці там.", "translation": "男孩们在那里。（飘忽 е 消失）" },
            { "text": "Учні тут.", "translation": "学生们在这里。（飘忽 е 消失）" },
            { "text": "Зайці там.", "translation": "兔子们在那里。（飘忽 е，є→й）" },
            { "text": "Діти тут.", "translation": "孩子们在这里。（不规则）" },
            { "text": "Люди — друзі.", "translation": "人们是朋友。（两个不规则复数同时出现）" },
            { "text": "Очі — це вікно душі.", "translation": "眼睛是心灵的窗户。（очі 不规则；душі 暂不强求）" },
            { "text": "Імена — там.", "translation": "名字（们）在那里。（ім'я → імена 不规则）" }
          ]
        }
      ]
