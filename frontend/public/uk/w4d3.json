            ["заєць", "<span class=\"uk-word\" data-def=\"兔子们\">зайці</span>", "<span class=\"uk-word\" data-def=\"兔子（宾）\">зайця</span>", "兔子 — е 消失 + є → й"],
            ["стілець", "<span class=\"uk-word\" data-def=\"椅子们\">стільці</span>", "<span class=\"uk-word\" data-def=\"椅子（宾，无生命=主）\">стілець</span>", "椅子 — е 消失"],
            ["палець", "<span class=\"uk-word\" data-def=\"手指（复）\">пальці</span>", "—（无生命）", "手指 — е 消失"],
            ["хлопець", "<span class=\"uk-word\" data-def=\"男孩们\">хлопці</span>", "<span class=\"uk-word\" data-def=\"男孩（宾）\">хлопця</span>", "男孩 — е 消失"],
            ["продавець", "<span class=\"uk-word\" data-def=\"售货员们\">продавці</span>", "<span class=\"uk-word\" data-def=\"售货员（宾）\">продавця</span>", "售货员 — е 消失"],
            ["олівець", "<span class=\"uk-word\" data-def=\"铅笔（复）\">олівці</span>", "—（无生命）", "铅笔 — е 消失"],
            ["учень", "<span class=\"uk-word\" data-def=\"学生们\">учні</span>", "<span class=\"uk-word\" data-def=\"学生（宾）\">учня</span>", "学生 — е 消失"]
          ]
        },
        { "type": "tip", "html": "<strong>记忆技巧：</strong>看到 <strong>-ець / -ень / -ір</strong> 结尾的阳性词，自动启动「飘忽元音」雷达 —— 90% 的情况是变复数 / 变格时这个 е 或 і 会消失。" },

        { "type": "h3", "text": "必须背熟的不规则复数" },
        {
          "type": "table",
          "headers": ["单数", "复数", "中文", "备注"],
