          "instruction": "选出每个名词的正确复数形式。",
          "questions": [
            {
              "prompt": "<span class=\"uk-word\" data-def=\"桌子\">стіл</span> 的复数是？",
              "options": ["столи", "столі", "стола"],
              "answer": "столи",
              "explanation": "阳性辅音结尾 → -и。",
              "hints": ["阳性常规规则"]
            },
            {
              "prompt": "<span class=\"uk-word\" data-def=\"老师（阳）\">вчитель</span> 的复数是？",
              "options": ["вчители", "вчителі", "вчителя"],
              "answer": "вчителі",
              "explanation": "阳性 ь / -й 结尾 → -і。"
            },
            {
              "prompt": "<span class=\"uk-word\" data-def=\"公园\">парк</span> 的复数是？",
              "options": ["парки", "паркі", "парка"],
              "answer": "парки",
              "explanation": "阳性后舌音 -к 结尾 → -и（拼写规则要求 к 后只能跟 -и 不能跟 -і）。",
