# ===================================
# 后端环境变量配置（Flask + SQLAlchemy，python-dotenv 加载）
# ===================================
# 复制此文件为 .env 并填入实际值
#
# 后端职责：关系生成 + TTS 缓存 + 外部 AI 代理（LLM / STT / TTS）。
# 所有外部 AI 调用（OpenAI 兼容 / Google Speech / Google TTS）的 key 都收敛在这里。

# --- 必填 ---

# Supabase PostgreSQL 连接串（pooler 模式，端口 6543，密码 URL-encode）
# 从 Supabase Dashboard → Project Settings → Database → Connection string (Transaction pooler) 复制
# 格式: postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxx:[YOUR-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:6543/postgres

# Supabase 项目 URL（用于 JWKS endpoint）
SUPABASE_URL=https://xxx.supabase.co

# --- 认证回退 ---

# Supabase JWT Secret（HS256 回退验证，仅本地开发/JWKS 不可用时用）
# 生产优先走 JWKS（P-256），此项可留空
SUPABASE_JWT_SECRET=

# --- 可选 ---

# TTS 音频缓存目录（默认 /opt/vocabulary_app/tts-cache，生产由部署脚本准备）
# TTS_CACHE_DIR=/opt/vocabulary_app/tts-cache

# CORS 允许的来源（逗号分隔；生产应设为前端域名，如 https://mieltsm.top）
CORS_ORIGINS=*

# Flask 调试模式（仅开发环境设为 1）
FLASK_DEBUG=0

# --- 外部 AI 代理（POST /api/ai/chat | /api/ai/transcribe | /api/ai/synthesize）---
#
# 上游采用 OpenAI 兼容协议（统一 base URL + 一把 API key，通过 model 字段路由到
# 不同供应商）。推荐网关：aihubmix、anyrouter 等。
#
# 三个路径：
#   POST {AI_BASE_URL}/chat/completions    — LLM 同步/流式
#   POST {AI_BASE_URL}/audio/transcriptions — STT (multipart file 上传)
#   POST {AI_BASE_URL}/audio/speech         — TTS (JSON 输入，二进制音频输出)

AI_BASE_URL=https://llm-proxy.tapsvc.com/v1
AI_API_KEY=

# 各路径的默认 model（用户可在 Settings 里覆盖 LLM；STT/TTS 默认覆盖存 user_config.config.aiSttModel/aiTtsModel）
AI_DEFAULT_MODEL=gemini-3-flash-preview
AI_DEFAULT_STT_MODEL=gpt-4o-mini-transcribe
AI_DEFAULT_TTS_MODEL=elevenlabs/eleven_multilingual_v2
# TTS 声音 id（OpenAI: alloy/echo/fable/onyx/nova/shimmer；ElevenLabs: voice_id）
AI_DEFAULT_TTS_VOICE=alloy
